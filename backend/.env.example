# Database
DATABASE_URL=postgresql://user:password@localhost:5432/tradeiq

# JWT
JWT_ACCESS_SECRET=your_access_token_secret_here
JWT_REFRESH_SECRET=your_refresh_token_secret_here

# Email (use Gmail SMTP or SendGrid)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password_here
EMAIL_FROM=TradeIQ <noreply@tradeiq.app>

# App
PORT=3001
FRONTEND_URL=http://localhost:3000
NODE_ENV=development

# Admin (first user to register with this email gets admin role automatically)
ADMIN_EMAIL=your_admin_email@example.com

# NOTE: No external stock API key needed. yahoo-finance2 works server-side
# without any API key. Users never see or configure any API keys.
